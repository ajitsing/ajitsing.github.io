---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:news="http://www.google.com/schemas/sitemap-news/0.9">
  {% assign dev_weekly_posts = site.posts | where_exp: "item", "item.tags contains 'dev-weekly'" %}
  {% for post in dev_weekly_posts limit:10 %}
  <url>
    <loc>{{ post.url | absolute_url }}</loc>
    <news:news>
      <news:publication>
        <news:name>Ajit Singh Blog</news:name>
        <news:language>en</news:language>
      </news:publication>
      <news:publication_date>{{ post.date | date_to_xmlschema }}</news:publication_date>
      <news:title>{{ post.title | xml_escape }}</news:title>
    </news:news>
  </url>
  {% endfor %}
</urlset>
